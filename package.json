{
  "name": "proyecto-antigravity-contratos",
  "version": "1.0.0",
  "description": "Sistema de Gestión de Contratos SQL y Supabase con Fallback",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "build": "rimraf dist && tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --detectOpenHandles",
    "seed": "ts-node src/seed.ts",
    "auto-push": "node scripts/push.js"
  },
  "keywords": [
    "express",
    "sqlite3",
    "supabase",
    "typescript",
    "zod",
    "jest"
  ],
  "author": "GBS Solutions",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.110.8",
    "@types/multer": "^2.2.0",
    "@types/pdf-parse": "^1.1.5",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "multer": "^2.2.0",
    "pdf-parse": "^2.4.5",
    "sqlite3": "^6.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tesseract.js": "^7.0.0",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^6.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.0.2",
    "jest": "^29.7.0",
    "jest-util": "^30.4.1",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
